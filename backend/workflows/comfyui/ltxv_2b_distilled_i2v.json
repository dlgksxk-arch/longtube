{
  "_meta": {
    "name": "LTX Video 2B 0.9.8 distilled (image-to-video)",
    "notes": "Lightricks LTXV 2B 증류 버전. 8 steps, cfg 1.0, euler. 12GB VRAM 에 여유롭게 돌아감. 640x384 @ 24fps. 해상도는 32 배수. T5-XXL 텍스트 인코더 별도 로드 필요 (CLIPLoader)."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ltxv-2b-0.9.8-distilled.safetensors"
    }
  },
  "14": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "t5xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "ltxv"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "${INPUT_IMAGE_NAME}"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": "${PROMPT}"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": "${NEGATIVE}"
    }
  },
  "5": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "vae": ["1", 2],
      "image": ["2", 0],
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "length": "${LENGTH}",
      "batch_size": 1,
      "strength": 1.0,
      "image_noise_scale": 0.05
    }
  },
  "6": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["5", 1],
      "frame_rate": 16
    }
  },
  "7": {
    "class_type": "ModelSamplingLTXV",
    "inputs": {
      "model": ["1", 0],
      "max_shift": 2.05,
      "base_shift": 0.95
    }
  },
  "8": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 10,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": true,
      "terminal": 0.1,
      "latent": ["5", 2]
    }
  },
  "9": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "10": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["7", 0],
      "add_noise": true,
      "noise_seed": "${SEED}",
      "cfg": 1.2,
      "positive": ["6", 0],
      "negative": ["6", 1],
      "sampler": ["9", 0],
      "sigmas": ["8", 0],
      "latent_image": ["5", 2]
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "12": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["11", 0],
      "fps": 16
    }
  },
  "13": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["12", 0],
      "filename_prefix": "${PREFIX}",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
