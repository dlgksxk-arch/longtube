{
  "_meta": {
    "name": "LTX Video 13B 0.9.8 distilled fp8 (image-to-video)",
    "notes": "Lightricks LTXV 13B 0.9.8 distilled fp8. 8 steps, cfg 1.0, euler. v1.1.60 수정: distilled fp8 체크포인트에는 CLIP(T5) 이 번들되어 있지 않아 CLIPLoader 로 따로 로드해서 물려준다. 32 배수 해상도, 8n+1 프레임, 24fps.",
    "requires": "ComfyUI/models/text_encoders/t5xxl_fp16.safetensors (또는 t5xxl_fp8_e4m3fn.safetensors). ComfyUI/models/checkpoints/ltxv-13b-0.9.8-distilled-fp8.safetensors."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ltxv-13b-0.9.8-distilled-fp8.safetensors"
    }
  },
  "2": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "${INPUT_IMAGE_NAME}"
    }
  },
  "14": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
      "type": "ltxv",
      "device": "default"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": "${PROMPT}"
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": "${NEGATIVE}"
    }
  },
  "5": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "vae": ["1", 2],
      "image": ["2", 0],
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "length": "${LENGTH}",
      "batch_size": 1,
      "strength": 1.0,
      "image_noise_scale": 0.3
    }
  },
  "6": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["5", 1],
      "frame_rate": 24
    }
  },
  "7": {
    "class_type": "ModelSamplingLTXV",
    "inputs": {
      "model": ["1", 0],
      "max_shift": 2.05,
      "base_shift": 0.95
    }
  },
  "8": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 8,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": true,
      "terminal": 0.1,
      "latent": ["5", 2]
    }
  },
  "9": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "10": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["7", 0],
      "add_noise": true,
      "noise_seed": "${SEED}",
      "cfg": 1.0,
      "positive": ["6", 0],
      "negative": ["6", 1],
      "sampler": ["9", 0],
      "sigmas": ["8", 0],
      "latent_image": ["5", 2]
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "12": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["11", 0],
      "fps": 24
    }
  },
  "13": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["12", 0],
      "filename_prefix": "${PREFIX}",
      "format": "mp4",
      "codec": "h264"
    }
  }
}
