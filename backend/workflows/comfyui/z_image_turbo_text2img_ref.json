{
  "_meta": {
    "name": "Z-Image Turbo bf16 text-to-image (ref-compat, IPAdapter-free)",
    "notes": "레퍼런스 픽셀 주입 제거. ${REF_IMAGE_NAME} 무시. 스타일은 프롬프트로 유도."
  },
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "z_image_turbo_bf16.safetensors", "weight_dtype": "default"}
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {"clip_name": "qwen_3_4b.safetensors", "type": "qwen_image", "device": "default"}
  },
  "3": {"class_type": "VAELoader", "inputs": {"vae_name": "ae.safetensors"}},
  "5": {"class_type": "CLIPTextEncode", "inputs": {"clip": ["2", 0], "text": "${PROMPT}"}},
  "6": {"class_type": "CLIPTextEncode", "inputs": {"clip": ["2", 0], "text": ""}},
  "7": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {"width": "${WIDTH}", "height": "${HEIGHT}", "batch_size": 1}
  },
  "8": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0], "positive": ["5", 0], "negative": ["6", 0], "latent_image": ["7", 0],
      "seed": "${SEED}", "steps": 8, "cfg": 1.0, "sampler_name": "euler", "scheduler": "simple", "denoise": 1.0
    }
  },
  "9": {"class_type": "VAEDecode", "inputs": {"samples": ["8", 0], "vae": ["3", 0]}},
  "10": {"class_type": "SaveImage", "inputs": {"images": ["9", 0], "filename_prefix": "${PREFIX}"}}
}
