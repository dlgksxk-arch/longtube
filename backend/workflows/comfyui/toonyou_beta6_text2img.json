{
  "_meta": {
    "name": "ToonYou Beta 6 text-to-image (SD 1.5 anime/cartoon)",
    "notes": "Civitai ToonYou Beta 6 — SD 1.5 기반 카툰/애니 스타일 체크포인트. ~2GB VRAM. 25 steps, cfg 7.0, dpmpp_2m/karras. 512 native, 768x448 / 448x768 / 512x512 권장."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "toonyou_beta6.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "${PROMPT}"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "${NEGATIVE}"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "${SEED}",
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "${PREFIX}"
    }
  }
}
