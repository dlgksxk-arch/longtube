{
  "_meta": {
    "name": "DreamShaper XL Lightning DPM++ SDE text-to-image (SDXL)",
    "notes": "Civitai DreamShaper XL SFW Lightning DPM++ SDE. SDXL 기반, Lightning LoRA 머지됨. 6-8 steps, cfg 2.0, dpmpp_sde/karras. VAE 내장. ~7GB VRAM. 1024 native (16:9 → 1344x768, 9:16 → 768x1344, 1:1 → 1024x1024)."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "dreamshaperXL_sfwLightningDPMSDE.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "${PROMPT}"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "${NEGATIVE}"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "${SEED}",
      "steps": 8,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "${PREFIX}"
    }
  }
}
