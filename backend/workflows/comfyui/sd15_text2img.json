{
  "_meta": {
    "name": "SD 1.5 text-to-image (vanilla, 25 steps)",
    "notes": "가장 가벼운 옵션. UNET ~860M + CLIP ~125M + VAE ~84M = 총 ~2GB VRAM. 12GB 에 여유롭게 돌아감. 장당 2-5초 예상. 512x512 / 512x768 / 768x512 권장 (훈련 해상도). 그 이상은 품질 저하."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly-fp16.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "${PROMPT}"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "${NEGATIVE}"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "${SEED}",
      "steps": 25,
      "cfg": 7.0,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "${PREFIX}"
    }
  }
}
