{
  "_meta": {
    "name": "DreamShaper XL Lightning + LongTube Style LoRA",
    "notes": "DreamShaper XL + 커스텀 LongTube 스타일 LoRA. GPT Image 1 스타일을 학습시킨 LoRA. trigger word: longtube style. LoRA weight 0.85 권장. 8 steps, cfg 2.0, dpmpp_sde/karras."
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "dreamshaperXL_sfwLightningDPMSDE.safetensors"
    }
  },
  "8": {
    "class_type": "LoraLoader",
    "inputs": {
      "model": ["1", 0],
      "clip": ["1", 1],
      "lora_name": "longtube_style_v1.safetensors",
      "strength_model": 0.85,
      "strength_clip": 0.85
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["8", 1],
      "text": "${PROMPT}"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["8", 1],
      "text": "${NEGATIVE}"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "width": "${WIDTH}",
      "height": "${HEIGHT}",
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["8", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0],
      "seed": "${SEED}",
      "steps": 8,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "${PREFIX}"
    }
  }
}
